# syntax=docker/dockerfile:1
#
# Build vllm v0.15.1 with free-threaded Python 3.14t using uv (CPU backend).
#
# Usage:
#   docker build -f Dockerfile.cpu -t vllm-freethreaded-cpu .
#   docker run -e PYTHON_GIL=0 vllm-freethreaded-cpu python -c "import vllm; print(vllm.__version__)"
#
# CPU ISA build arguments (for cross-compilation):
#   VLLM_CPU_DISABLE_AVX512=0 (default)
#   VLLM_CPU_AVX2=0, VLLM_CPU_AVX512=0, VLLM_CPU_AVX512BF16=0
#   VLLM_CPU_AVX512VNNI=0, VLLM_CPU_AMXBF16=1, VLLM_CPU_ARM_BF16=0
#
# Written with help from Claude Opus 4.6.

# ---------------------------------------------------------------------------
# build — System packages, uv, Python, Rust, source builds
# ---------------------------------------------------------------------------
FROM ubuntu:24.04 AS build

ENV DEBIAN_FRONTEND=noninteractive

ARG TARGETARCH

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt/lists,sharing=locked \
    rm -f /etc/apt/apt.conf.d/docker-clean \
    && apt-get update && apt-get install -y --no-install-recommends \
        git \
        ccache \
        numactl \
        libnuma-dev \
        g++ \
        curl \
        pkg-config \
        libssl-dev \
        protobuf-compiler \
        ca-certificates

# Install uv
COPY --from=ghcr.io/astral-sh/uv:0.10.2 /uv /uvx /bin/

WORKDIR /app

# Create a free-threaded Python 3.14t venv
RUN uv venv /app/.venv --python cpython-3.14t
ENV VIRTUAL_ENV=/app/.venv
ENV PATH="/app/.venv/bin:${PATH}"
ENV UV_LINK_MODE=copy

# Set git identity (needed for git am in clone-repos.py)
RUN git config --global user.email "build@docker.example.com" \
    && git config --global user.name "Docker Build"

ARG MAX_JOBS="4"

# CPU ISA build arguments
ARG VLLM_CPU_DISABLE_AVX512=0
ARG VLLM_CPU_AVX2=0
ARG VLLM_CPU_AVX512=0
ARG VLLM_CPU_AVX512BF16=0
ARG VLLM_CPU_AVX512VNNI=0
ARG VLLM_CPU_AMXBF16=1
ARG VLLM_CPU_ARM_BF16=0

# Propagate ISA args to env for the vllm build
ENV VLLM_CPU_DISABLE_AVX512=${VLLM_CPU_DISABLE_AVX512}
ENV VLLM_CPU_AVX2=${VLLM_CPU_AVX2}
ENV VLLM_CPU_AVX512=${VLLM_CPU_AVX512}
ENV VLLM_CPU_AVX512BF16=${VLLM_CPU_AVX512BF16}
ENV VLLM_CPU_AVX512VNNI=${VLLM_CPU_AVX512VNNI}
ENV VLLM_CPU_AMXBF16=${VLLM_CPU_AMXBF16}
ENV VLLM_CPU_ARM_BF16=${VLLM_CPU_ARM_BF16}

# Install Rust (cached across builds; not stored in image layers)
ENV CARGO_HOME=/root/.cargo
ENV RUSTUP_HOME=/root/.rustup
ENV PATH=/root/.cargo/bin:$PATH

RUN --mount=type=cache,target=/root/.rustup \
    --mount=type=cache,target=/root/.cargo \
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --profile minimal

ADD requirements/torch.txt /tmp/r
RUN --mount=type=cache,target=/root/.cache/uv \
    --mount=type=cache,target=/root/.rustup \
    --mount=type=cache,target=/root/.cargo \
    UV_HTTP_TIMEOUT=200 \
    uv pip install -r /tmp/r \
        --extra-index-url https://download.pytorch.org/whl/cpu

ADD requirements/common.txt /tmp/r
RUN --mount=type=cache,target=/root/.cache/uv \
    --mount=type=cache,target=/root/.rustup \
    --mount=type=cache,target=/root/.cargo \
    UV_HTTP_TIMEOUT=200 uv pip install -r /tmp/r

# Validate ISA flags — prevent mixing x86/ARM flags
RUN if [ "$TARGETARCH" = "arm64" ] && { [ "$VLLM_CPU_AVX2" != "0" ] || [ "$VLLM_CPU_AVX512" != "0" ] || [ "$VLLM_CPU_AVX512BF16" != "0" ] || [ "$VLLM_CPU_AVX512VNNI" != "0" ]; }; then \
        echo "ERROR: Cannot use x86-specific ISA flags (AVX2, AVX512, etc.) when building for ARM64"; \
        exit 1; \
    fi && \
    if [ "$TARGETARCH" = "amd64" ] && [ "$VLLM_CPU_ARM_BF16" != "0" ]; then \
        echo "ERROR: Cannot use ARM-specific ISA flags (ARM_BF16) when building for x86_64"; \
        exit 1; \
    fi

# Copy clone infrastructure
COPY clone-repos.py git-repos.txt ./
COPY patches/ patches/

# Clone required repos (no flash-attention or triton for CPU)
RUN python clone-repos.py \
        --repo vllm

# Build vllm from source (editable — source tree needed at runtime)
RUN --mount=type=cache,target=/root/.cache/uv \
    --mount=type=cache,target=/root/.ccache \
    CCACHE_DIR=/root/.ccache \
    VLLM_TARGET_DEVICE=cpu \
    MAX_JOBS="${MAX_JOBS}" \
    CC="ccache gcc" \
    CXX="ccache g++" \
    CMAKE_CXX_COMPILER_LAUNCHER=ccache \
    uv pip install -e third_party/vllm -v \
        --no-build-isolation --no-deps

# staging — Assemble only the files needed at runtime
RUN set -eux \
    # --- Create staging directory structure --- \
    && mkdir -p /staging/root/.local/share/uv \
                /staging/app \
    # --- Python venv + the uv-managed Python it symlinks into --- \
    && mv /app/.venv /staging/app/.venv \
    && mv /root/.local/share/uv/python /staging/root/.local/share/uv/python \
    # --- vllm source (editable install needs this at runtime) --- \
    && mkdir -p /staging/app/third_party \
    && mv /app/third_party/vllm /staging/app/third_party/vllm \
    && rm -rf /staging/app/third_party/vllm/vllm/.deps

# ---------------------------------------------------------------------------
# runtime — Production image
# ---------------------------------------------------------------------------
FROM ubuntu:24.04 AS runtime

ENV DEBIAN_FRONTEND=noninteractive

# Runtime system dependencies
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt/lists,sharing=locked \
    rm -f /etc/apt/apt.conf.d/docker-clean \
    && apt-get update && apt-get install -y --no-install-recommends \
        vim-tiny \
        less \
        git \
        numactl \
        libgomp1 \
        ca-certificates \
        gcc \
        g++ \
        libc6-dev

# All runtime files in a single COPY layer
COPY --from=build /staging/ /

# Refresh the dynamic linker cache
RUN ldconfig

# Environment
ENV VIRTUAL_ENV=/app/.venv
ENV PATH="/app/.venv/bin:${PATH}"
ENV PYTHON_GIL=0

WORKDIR /app
